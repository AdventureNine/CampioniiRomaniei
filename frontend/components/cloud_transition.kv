#:import Window kivy.core.window.Window

<CloudTransitionLayout>:
    id: cloud_layout
    Widget:
        id: left_cloud
        size_hint: 0.6, 1
        x: -self.width
        pos_hint: {'y': 0}
        canvas:
            Color:
                rgba: 1, 1, 1, 1
            Ellipse:
                pos: self.x, self.y
                size: self.width, self.height
            Ellipse:
                pos: self.x + 50, self.y + 100
                size: self.width, self.height * 0.8
            Ellipse:
                pos: self.x - 50, self.y - 100
                size: self.width, self.height * 0.8

    Widget:
        id: right_cloud
        size_hint: 0.6, 1
        x: Window.width
        pos_hint: {'y': 0}
        canvas:
            Color:
                rgba: 1, 1, 1, 1
            Ellipse:
                pos: self.x - 100, self.y
                size: self.width, self.height
            Ellipse:
                pos: self.x - 150, self.y + 150
                size: self.width, self.height * 0.7
            Ellipse:
                pos: self.x - 50, self.y - 150
                size: self.width, self.height * 0.7